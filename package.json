{
  "name": "magnocorp-othub",
  "version": "1.5.1",
  "description": "MagnoCorpOTHub: the unified OT reporting and analytics platform for industrial automation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:mock": "tsx watch src/dev-server.ts",
    "build": "node scripts/generate-build-metadata.js && tsc && tsc-alias",
    "build:client": "cd client && npm run build",
    "build:all": "npm run build && npm run build:client",
    "start": "node dist/server.js",
    "start:build": "node dist/server.js",
    "start:dev": "concurrently \"npm run dev\" \"cd client && PORT=3000 npm start\"",
    "start:dev:mock": "concurrently \"npm run dev:mock\" \"cd client && PORT=3000 npm start\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:property": "jest --testNamePattern='Property'",
    "lint": "eslint src/**/*.ts",
    "docker:build": "docker buildx build --platform linux/amd64,linux/arm64 -t magnocorp-othub .",
    "docker:dev": "docker-compose up --build",
    "setup:db": "tsx scripts/setup-database-configs.ts",
    "test:db": "tsx scripts/test-database-connections.ts",
    "teve:verify": "tsx scripts/historian/verify-db.ts",
    "teve:dev": "tsx src/historian/index.ts",
    "teve:api:start": "node dist/historian/api.js",
    "teve:worker:start": "node dist/historian/worker.js",
    "teve:warmup-model": "tsx scripts/historian/warmup-model.ts",
    "teve:migrate": "tsx scripts/historian/migrate.ts",
    "teve:backfill": "tsx scripts/historian/backfill-embeddings.ts",
    "teve:eval": "tsx scripts/historian/teve-eval.ts",
    "teve:up": "docker compose -f docker-compose.historian.yml up -d",
    "teve:down": "docker compose -f docker-compose.historian.yml down"
  },
  "keywords": [
    "historian",
    "reporting",
    "aveva",
    "time-series",
    "industrial"
  ],
  "author": "Ricardo A",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@graphql-tools/schema": "^10.0.0",
    "@types/redis": "^4.0.10",
    "@xenova/transformers": "^2.17.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.18.1",
    "bull": "^4.12.0",
    "graphql": "^16.8.0",
    "pg": "^8.11.0",
    "pgvector": "^0.2.0",
    "pino": "^8.16.0",
    "puppeteer": "^22.0.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.11.1",
    "call-bind-apply-helpers": "^1.0.1",
    "canvas": "^3.2.3",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "dunder-proto": "^1.0.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "get-intrinsic": "^1.2.4",
    "get-proto": "^1.0.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.2.0",
    "iconv-lite": "^0.7.2",
    "jsonwebtoken": "^9.0.2",
    "ldapts": "^8.1.8",
    "mssql": "^10.0.1",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-opcua": "^2.163.1",
    "nodemailer": "^6.9.7",
    "path-to-regexp": "^8.3.0",
    "pdfkit": "^0.14.0",
    "redis": "^5.10.0",
    "sharp": "^0.33.0",
    "side-channel": "^1.1.0",
    "socket.io": "^4.8.3",
    "svg-to-pdfkit": "^0.1.8",
    "uuid": "^10.0.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bcrypt": "^5.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.7.4",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^29.5.7",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/mssql": "^9.1.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.8.9",
    "@types/pg": "^8.11.0",
    "@types/node-cron": "^3.0.9",
    "@types/nodemailer": "^6.4.13",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.12.12",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.52.0",
    "fast-check": "^3.13.2",
    "jest": "^29.7.0",
    "pdf-parse": "^2.4.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.1.2",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "allowScripts": {
    "canvas@3.2.3": true,
    "better-sqlite3@12.11.1": true,
    "bcrypt@5.1.1": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
